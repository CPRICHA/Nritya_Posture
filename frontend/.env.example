# Local dev — talks to backend on port 8000
# VITE_API_URL=http://127.0.0.1:8000

# Production on Vercel (recommended — same-origin proxy, no CORS issues)
VITE_API_URL=/api
VITE_USE_API_PROXY=true

# Production direct to Render (only if not using Vercel rewrites)
# VITE_API_URL=https://nritya-backend-vcgv.onrender.com
